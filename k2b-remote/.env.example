# ===== REQUIRED =====

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Your Telegram numeric chat ID (send /chatid to the bot to get this)
ALLOWED_CHAT_ID=

# ===== VOICE (Groq STT) =====

# Groq API key for Whisper speech-to-text (free at console.groq.com)
GROQ_API_KEY=

# ===== PATHS (optional, auto-detected if k2b-remote is inside K2B/) =====

# K2B project root (where CLAUDE.md lives). Default: parent of k2b-remote/
#CLAUDE_PROJECT_ROOT=

# Obsidian vault path. Default: sibling K2B-Vault/ folder
#VAULT_PATH=

# ===== OPTIONAL =====

# Log level: debug, info, warn, error
LOG_LEVEL=info
