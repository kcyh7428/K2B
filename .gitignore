# Secrets
.env
*.env

# Dependencies
node_modules/

# Build output
dist/

# Runtime data
store/
*.log
*.pid
k2b-remote/tasks.db
k2b-remote/*.db

# Deferred-sync mailbox (local to each machine, never committed)
# One file per /ship --defer, consumed and deleted by /sync.
/.pending-sync/
# Legacy single-file marker, kept ignored for backward compatibility
/.pending-sync.json

# Temp media
workspace/uploads/

# Autoresearch iteration logs (per-skill, not committed)
**/eval/results.tsv

# Allhands presentation (side project, not K2B)
allhands/
docs/superpowers/specs/2026-03-30-allhands-presentation-design.md

# Side scripts (not K2B)
scripts/generate-org-chart.py

# MiniMax adversarial review artifacts (per-machine, not committed)
.minimax-reviews/

# Unified review runner archives (per-machine, not committed)
/.code-reviews/

# Claude Code plan artifacts
.claude/plans/

# Scheduler runtime lock (orphaned if a scheduler session dies uncleanly)
.claude/scheduled_tasks.lock

# superpowers:using-git-worktrees stub dir (created empty by the skill).
# Left untracked, it crashes Codex's `read()` walk with EISDIR and forces
# scripts/review.sh to fall back to MiniMax on every commit.
.claude/worktrees/

# Per-machine Claude Code local settings (anywhere in tree). Same EISDIR
# hazard as above when the `.claude/` dir it lives in has no tracked files.
**/settings.local.json

# Sub-project Claude Code dirs. Only the repo-root .claude/ has tracked
# content (skills, settings, plans). Sub-projects keep their own local
# config that isn't shared -- ignoring the whole dir avoids the "parent
# has no tracked files" EISDIR hazard.
/k2b-remote/.claude/
/k2b-dashboard/.claude/

# Python bytecode cache
__pycache__/
*.pyc

# Per-machine Python venvs (Washing Machine MacBook + Mini both use this
# path; the Mini's venv is created by scripts/washing-machine/preflight.sh
# and the MacBook's by its equivalent setup. ~700MB of torch deps, never
# committed).
/venv/

# OS files
.DS_Store
k2b-dashboard/.env
k2b-dashboard/node_modules/
k2b-dashboard/dist/
