{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash(git *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(python3 *)",
      "Bash(node *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(ssh macmini *)",
      "Bash(rsync *)",
      "Bash(gws *)",
      "Bash(jq *)",
      "Bash(wc *)",
      "Bash(mkdir *)",
      "Bash(mv *)",
      "Bash(cp *)",
      "Bash(chmod *)",
      "Bash(curl *)",
      "Bash(brew *)",
      "Bash(pm2 *)",
      "Bash(yt-dlp *)",
      "Bash(whisper *)",
      "WebSearch",
      "WebFetch",
      "mcp__obsidian__*",
      "mcp__youtube-transcript__*",
      "mcp__exa__*",
      "mcp__minimax__*",
      "mcp__airtable-keith__*"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/hooks/session-start.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/hooks/post-tool-skill-track.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/hooks/stop-observe.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}